# ─── Base de Datos ────────────────────────────────────────
DATABASE_URL="postgresql://twonick_user:PASSDB@localhost:5432/twonick_db"

# ─── Redis ────────────────────────────────────────────────
REDIS_URL="redis://:PASSWRREDIS@localhost:6379"

# ─── JWT (genera con: openssl rand -hex 64) ───────────────
JWT_ACCESS_SECRET="openssl rand -hex 64"
JWT_REFRESH_SECRET="openssl rand -hex 32"

# ─── Cifrado MT5 (genera con: openssl rand -hex 32) ───────
MT5_ENCRYPTION_KEY="openssl rand -hex 32"

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── Binance Pay ──────────────────────────────────────────
BINANCE_PAY_API_KEY=""
BINANCE_PAY_SECRET_KEY=""

# ─── VPS MT5 (genera con: openssl rand -hex 32) ──────────
VPS_API_KEY="reemplaza_con_key_secreta_del_vps"

# ─── Bunny.net Stream ─────────────────────────────────────
BUNNY_LIBRARY_ID="610734"
BUNNY_API_KEY="tu-api-key-de-bunny"
BUNNY_CDN_HOSTNAME="vz-f386cc92-408.b-cdn.net"
# Opcional: Pull Zone Token Auth Key (Bunny Dashboard → CDN → Pull Zone → Token Auth)
# Si no se configura, se usa BUNNY_API_KEY para HLS. Sólo necesario para URLs HLS directas.
BUNNY_TOKEN_AUTH_KEY=""

# ─── App ──────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
