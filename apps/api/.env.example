# ─── Base de Datos ────────────────────────────────────────
DATABASE_URL="postgresql://twonick_user:TU_PASSWORD@localhost:5432/twonick_db"

# ─── Redis ────────────────────────────────────────────────
REDIS_URL="redis://:TU_REDIS_PASSWORD@localhost:6379"

# ─── JWT (genera con: openssl rand -hex 64) ───────────────
JWT_ACCESS_SECRET="reemplaza_con_64_bytes_hex"
JWT_REFRESH_SECRET="reemplaza_con_otro_64_bytes_hex"

# ─── Cifrado MT5 (genera con: openssl rand -hex 32) ───────
MT5_ENCRYPTION_KEY="reemplaza_con_32_bytes_hex"

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── Binance Pay ──────────────────────────────────────────
BINANCE_PAY_API_KEY=""
BINANCE_PAY_SECRET_KEY=""

# ─── App ──────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
