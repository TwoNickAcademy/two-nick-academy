# ─── Base de Datos ────────────────────────────────────────
DATABASE_URL="postgresql://twonick_user:PASSDB@localhost:5432/twonick_db"

# ─── Redis ────────────────────────────────────────────────
REDIS_URL="redis://:PASSWRREDIS@localhost:6379"

# ─── JWT (genera con: openssl rand -hex 64) ───────────────
JWT_ACCESS_SECRET="openssl rand -hex 64"
JWT_REFRESH_SECRET="openssl rand -hex 32""
# ─── Cifrado MT5 (genera con: openssl rand -hex 32) ───────
MT5_ENCRYPTION_KEY="openssl rand -hex 32"

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── Binance Pay ──────────────────────────────────────────
BINANCE_PAY_API_KEY=""
BINANCE_PAY_SECRET_KEY=""

# ─── App ──────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
